# Manual
ignore/

# WAD files — commercial titles cannot be redistributed
# DOOM1.WAD (shareware) is freely distributable and is intentionally included
*.WAD
*.wad
!**/DOOM1.WAD
!**/doom1.wad

# PWAD/mod files — user-supplied; not redistributable
assets/pwads/*.wad
assets/pwads/*.WAD
assets/pwads/*.pk3
assets/pwads/*.pk7

# Soundfonts — ~99 MB of Base64-encoded MP3 audio, fetched by get-assets.bat/.sh
# CC-BY 3.0 (FluidR3_GM) and MIT licenses permit redistribution, but the size is prohibitive
assets/soundfonts/

# Third-party logos (trademarks — not redistributable)
assets/branding/

# Maven build artifacts
**/target/
**/*.modl

# Module staging/build directory (JARs, XMLs, ZIPs — all build output)
ignition-module/build/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Java build outputs
*.class
*.log
*.jar
*.war
*.ear

# IDE
.idea/
*.iml
.vscode/
.settings/
.project
.classpath

# Editor temp files
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
